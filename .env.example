# YouTube Data API Key
# Get a key from Google Cloud Console: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Analytics API OAuth2 Credentials (Optional, for private video analytics)
# Generate client credentials in Google Cloud Console and run get_refresh_token.py
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here
